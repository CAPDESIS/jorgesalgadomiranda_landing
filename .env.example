# FTP credentials for manual deploy via scripts/deploy.sh
FTP_HOST=ftp.jorgesalgadomiranda.com
FTP_USER=your-ftp-username
FTP_PASS=your-ftp-password
FTP_REMOTE_DIR=/public_html

# Cal.com personal API key (for scripts that manage event types / bookings).
# Create at app.cal.com/settings/developer/api-keys. Scope is your own user.
# Never paste the real value into committed files; keep it in .env (gitignored).
CAL_API_KEY=your-cal-com-api-key

# PostHog Analytics
# Get your project API key from: https://us.posthog.com/settings/project
# Injected into index.html at deploy time via .github/workflows/deploy.yml
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Contact form (Resend primary — injected into api/secrets.php at deploy, never HTML)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Jorge Salgado Miranda <noreply@jorgesalgadomiranda.com>
# RESEND_TO=jorgesalgadomiranda@protonmail.com
# RESEND_REPLY_TO=jorgesalgadomiranda@protonmail.com
# Optional SMTP fallback only (quota/outage):
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=465
# SMTP_USER=noreply@jorgesalgadomiranda.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=Jorge Salgado Miranda <noreply@jorgesalgadomiranda.com>
